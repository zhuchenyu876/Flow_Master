#  =======================
# 🖥️  服务器配置
# =======================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# =======================
# 🗄️  数据库配置
# =======================
DB_HOST=192.168.160.58
DB_PORT=3306
DB_NAME=cybertron_pre
DB_USER=cybertron
DB_PASSWORD=cybertron@2023
DB_ECHO=false

# =======================
# 🌐  API 配置
# =======================
DYNA_API_BASE=https://agents.dyna.ai

# =======================
# ⚙️  功能开关
# =======================
CREATE_KB=true
UPLOAD_AGENT=true

# =======================
# 🔧  并发配置
# =======================
# MAX_WORKERS: 最大并发任务数（线程池大小）
# - 1: 串行处理，一次只处理一个任务（默认，安全但慢）
# - 2-5: 适合小规模并发
# - 10+: 适合大规模批量处理（需确保系统资源充足）
MAX_WORKERS=1

# MAX_QUEUE_SIZE: 最大排队任务数
# - 0: 不限制队列大小
# - 100: 默认值，最多排队100个任务
MAX_QUEUE_SIZE=100

# =======================
# 📝  日志控制
# =======================
# LOG_LEVEL: 日志级别 (DEBUG, INFO, WARNING, ERROR)
# - DEBUG: 显示所有详细信息
# - INFO: 显示关键步骤信息（推荐）
# - WARNING: 只显示警告和错误
# - ERROR: 只显示错误
LOG_LEVEL=INFO

# VERBOSE_MODE: 详细模式开关
# - true: 显示所有内部处理细节（等同于 LOG_LEVEL=DEBUG）
# - false: 只显示关键步骤，隐藏细节（推荐）
VERBOSE_MODE=false

# =======================
# 🔄  Step 3 知识库配置
# =======================
# STEP_3_UPLOAD_WORKERS: 知识库上传并发数
# - 1: 串行上传（安全但慢）
# - 10: 默认值，适合大多数场景
# - 20+: 高并发（需确保网络和API稳定）
STEP_3_UPLOAD_WORKERS=10

# STEP_3_MAX_KB_NAME_LENGTH: 知识库名称最大长度
# - 128: 默认值（API限制）
STEP_3_MAX_KB_NAME_LENGTH=128

# STEP_3_KB_CREATE_RETRIES: 创建知识库的最大重试次数
# - 3: 默认值
STEP_3_KB_CREATE_RETRIES=3

# =======================
# 📞  回调配置
# =======================
# CALLBACK_URL: 任务完成后的回调地址（可选）
# - 如果不配置，将不会发送回调通知
# - 示例: http://your-server.com/api/callback
CALLBACK_URL=

# =======================
# 🔑  API 凭证（批量上传使用）
# =======================
# 英文版本
ROBOT_KEY=
ROBOT_TOKEN=
USERNAME=

# 简体中文版本
ROBOT_KEY_ZH_CN=
ROBOT_TOKEN_ZH_CN=

# 繁体中文版本
ROBOT_KEY_ZH_HK=
ROBOT_TOKEN_ZH_HK=

